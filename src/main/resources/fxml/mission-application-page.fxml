<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.healthtrack.controllers.MissionApplicationPageController"
            styleClass="page-scroll">
    <content>
        <VBox spacing="22.0" alignment="TOP_CENTER" styleClass="content-wrapper">
            <padding>
                <Insets top="32.0"/>
            </padding>
            <children>
                <VBox spacing="18.0" maxWidth="560.0" styleClass="application-form-card">
                    <children>
                        <VBox spacing="8.0" styleClass="application-form-header">
                            <children>
                                <Label text="Finaliser votre candidature" styleClass="application-form-title"/>
                                <Label fx:id="missionNameLabel" wrapText="true" styleClass="application-form-subtitle"/>
                            </children>
                        </VBox>
                        <Label text="Vos disponibilites pour cette mission" styleClass="field-label">
                            <VBox.margin>
                                <Insets right="22.0" left="22.0"/>
                            </VBox.margin>
                        </Label>
                        <GridPane hgap="10.0" vgap="10.0" styleClass="availability-grid">
                            <children>
                                <CheckBox fx:id="morningWeekBox" text="Semaine (Matin)" styleClass="availability-box" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                <CheckBox fx:id="afternoonWeekBox" text="Semaine (Apres-midi)" styleClass="availability-box" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                                <CheckBox fx:id="eveningWeekBox" text="Semaine (Soir)" styleClass="availability-box" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                <CheckBox fx:id="weekendMorningBox" text="Week-end (Matin)" styleClass="availability-box" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                                <CheckBox fx:id="weekendAfternoonBox" text="Week-end (Apres-midi)" styleClass="availability-box" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                            </children>
                        </GridPane>
                        <Label text="Pourquoi cette mission ? (Motivation)" styleClass="field-label">
                            <VBox.margin>
                                <Insets right="22.0" left="22.0"/>
                            </VBox.margin>
                        </Label>
                        <TextArea fx:id="motivationArea" text="Bonjour, je souhaite participer car..." wrapText="true" prefRowCount="5" styleClass="motivation-area">
                            <VBox.margin>
                                <Insets right="22.0" left="22.0"/>
                            </VBox.margin>
                        </TextArea>
                        <Label text="Confirmer vos coordonnees" styleClass="field-label">
                            <VBox.margin>
                                <Insets right="22.0" left="22.0"/>
                            </VBox.margin>
                        </Label>
                        <TextField fx:id="phoneField" text="+216 20 123 456" styleClass="contact-field">
                            <VBox.margin>
                                <Insets right="22.0" left="22.0"/>
                            </VBox.margin>
                        </TextField>
                        <HBox alignment="CENTER_RIGHT" spacing="12.0">
                            <VBox.margin>
                                <Insets right="22.0" bottom="22.0" left="22.0"/>
                            </VBox.margin>
                            <children>
                                <Button text="Annuler" onAction="#cancelApplication" styleClass="text-button"/>
                                <Button text="Envoyer ma candidature" onAction="#submitApplication" styleClass="action-button primary-button submit-application-button"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </content>
</ScrollPane>
