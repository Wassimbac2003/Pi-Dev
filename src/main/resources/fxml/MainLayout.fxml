<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.healthtrack.controllers.MainLayoutController"
            prefWidth="1400" prefHeight="860"
            style="-fx-background-color: #f0f4f8;">

    <!-- SIDEBAR -->
    <left>
        <VBox prefWidth="220" spacing="0"
              style="-fx-background-color: white; -fx-border-color: #e8e8e8; -fx-border-width: 0 1 0 0;">

            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 20 20 25 20;">
                <Label text="💙" style="-fx-font-size: 22;"/>
                <Label text="VitalTech" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1a73e8;"/>
            </HBox>

            <Label text="MENU PRINCIPAL"
                   style="-fx-font-size: 11; -fx-text-fill: #999; -fx-padding: 0 0 10 20; -fx-font-weight: bold;"/>

            <Button fx:id="btnTableauBord" text="  📊  Tableau de Bord" prefWidth="220" prefHeight="40" alignment="CENTER_LEFT"
                    style="-fx-background-color: transparent; -fx-text-fill: #555; -fx-font-size: 13; -fx-padding: 0 0 0 20; -fx-cursor: hand;"/>

            <Button fx:id="btnRendezVous" text="  📅  Rendez-vous" prefWidth="220" prefHeight="40" alignment="CENTER_LEFT"
                    style="-fx-background-color: #eef3ff; -fx-text-fill: #1a73e8; -fx-font-size: 13; -fx-font-weight: bold; -fx-padding: 0 0 0 20; -fx-cursor: hand; -fx-background-radius: 0;"/>

            <Button fx:id="btnMedicaments" text="  💊  Médicaments" prefWidth="220" prefHeight="40" alignment="CENTER_LEFT"
                    style="-fx-background-color: transparent; -fx-text-fill: #555; -fx-font-size: 13; -fx-padding: 0 0 0 20; -fx-cursor: hand;"/>

            <Button fx:id="btnStats" text="  📈  Mes Statistiques" prefWidth="220" prefHeight="40" alignment="CENTER_LEFT"
                    style="-fx-background-color: transparent; -fx-text-fill: #555; -fx-font-size: 13; -fx-padding: 0 0 0 20; -fx-cursor: hand;"/>

            <Region prefHeight="20"/>

            <Label text="COMMUNAUTÉ"
                   style="-fx-font-size: 11; -fx-text-fill: #999; -fx-padding: 0 0 10 20; -fx-font-weight: bold;"/>

            <Button fx:id="btnBenevolat" text="  🤝  Bénévolat" prefWidth="220" prefHeight="40" alignment="CENTER_LEFT"
                    style="-fx-background-color: transparent; -fx-text-fill: #555; -fx-font-size: 13; -fx-padding: 0 0 0 20; -fx-cursor: hand;"/>

            <Button fx:id="btnForum" text="  💬  Forum" prefWidth="220" prefHeight="40" alignment="CENTER_LEFT"
                    style="-fx-background-color: transparent; -fx-text-fill: #555; -fx-font-size: 13; -fx-padding: 0 0 0 20; -fx-cursor: hand;"/>

            <Button fx:id="btnAnnonces" text="  📢  Annonces &amp; Dons" prefWidth="220" prefHeight="40" alignment="CENTER_LEFT"
                    style="-fx-background-color: transparent; -fx-text-fill: #555; -fx-font-size: 13; -fx-padding: 0 0 0 20; -fx-cursor: hand;"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Separator/>

            <Button text="  👤  Mon compte" prefWidth="220" prefHeight="40" alignment="CENTER_LEFT"
                    style="-fx-background-color: transparent; -fx-text-fill: #555; -fx-font-size: 13; -fx-padding: 0 0 0 20; -fx-cursor: hand;"/>

            <Button text="  🚪  Déconnexion" prefWidth="220" prefHeight="40" alignment="CENTER_LEFT"
                    style="-fx-background-color: transparent; -fx-text-fill: #e53935; -fx-font-size: 13; -fx-padding: 0 0 0 20; -fx-cursor: hand;"/>

            <Region prefHeight="10"/>
        </VBox>
    </left>

    <!-- CONTENU PRINCIPAL -->
    <center>
        <VBox spacing="0" style="-fx-background-color: #f0f4f8;">

            <!-- HEADER -->
            <HBox alignment="CENTER_LEFT" spacing="15" prefHeight="200"
                  style="-fx-background-color: white; -fx-padding: 0 30; -fx-border-color: #e8e8e8; -fx-border-width: 0 0 1 0;">

                <Label fx:id="pageTitle" text="Bonjour, Nada"
                       style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #333;"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Label text="🔔" style="-fx-font-size: 18; -fx-cursor: hand;"/>

                <VBox alignment="CENTER_RIGHT" spacing="2">
                    <Label text="nada hmaied" style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                    <Label text="hmaied.nada1@gmail.com" style="-fx-font-size: 11; -fx-text-fill: #999;"/>
                </VBox>

                <Label text="NH" prefWidth="40" prefHeight="40" alignment="CENTER"
                       style="-fx-background-color: #1a73e8; -fx-background-radius: 20; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14;"/>
            </HBox>

            <!-- ZONE CONTENU DYNAMIQUE -->
            <StackPane fx:id="contentArea" VBox.vgrow="ALWAYS" style="-fx-padding: 25;"/>

        </VBox>
    </center>
</BorderPane>