<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.healthtrack.controllers.AdminMainController"
            styleClass="admin-shell">
    <left>
        <VBox prefWidth="262.0" spacing="14.0" styleClass="admin-sidebar">
            <padding>
                <Insets top="24.0" right="18.0" bottom="20.0" left="20.0"/>
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <children>
                        <Label text="🛡" styleClass="admin-brand-icon"/>
                        <Label text="ADMIN" styleClass="admin-brand-title"/>
                    </children>
                </HBox>
                <Separator styleClass="admin-separator"/>
                <Button text="Dashboard" onAction="#noop" styleClass="admin-side-link"/>
                <Button text="Utilisateurs" onAction="#noop" styleClass="admin-side-link"/>
                <Button text="Super Admin" onAction="#noop" styleClass="admin-side-link"/>
                <Button text="Vérifications" onAction="#noop" styleClass="admin-side-link"/>
                <Button text="Mon compte" onAction="#noop" styleClass="admin-side-link"/>
                <Label text="GESTION" styleClass="admin-side-section"/>
                <Button fx:id="benevolatAdminButton" text="Bénévolat" onAction="#showAdminMissionsPage" styleClass="admin-nav-button"/>
                <Button fx:id="rendezVousAdminButton" text="Rendez-vous" onAction="#noop" styleClass="admin-nav-button"/>
                <Button fx:id="annoncesAdminButton" text="Gestion Annonces" onAction="#showAdminSponsorsPage" styleClass="admin-side-link"/>
                <Button fx:id="donationsAdminButton" text="Gestion Donations" onAction="#noop" styleClass="admin-side-link"/>
                <Button fx:id="forumAdminButton" text="Forum" onAction="#noop" styleClass="admin-side-link"/>
                <Region VBox.vgrow="ALWAYS"/>
                <Separator styleClass="admin-separator"/>
                <Button text="Retour au frontoffice" onAction="#returnToFrontoffice" styleClass="admin-side-link"/>
                <Button text="Déconnexion" onAction="#noop" styleClass="admin-logout-link"/>
            </children>
        </VBox>
    </left>
    <center>
        <BorderPane styleClass="admin-content-shell">
            <top>
                <VBox spacing="4.0" styleClass="admin-topbar">
                    <padding>
                        <Insets top="18.0" right="30.0" bottom="18.0" left="30.0"/>
                    </padding>
                    <children>
                        <Label text="Planning des Consultations" styleClass="admin-top-title"/>
                        <Label text="Gérez les disponibilités et les rendez-vous patients" styleClass="admin-top-subtitle"/>
                    </children>
                </VBox>
            </top>
            <center>
                <StackPane fx:id="adminContentPane"/>
            </center>
        </BorderPane>
    </center>
</BorderPane>
