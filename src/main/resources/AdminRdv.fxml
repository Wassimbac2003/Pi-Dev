<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="Controllers.AdminRdvController"
            fitToWidth="true"
            style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">

    <VBox spacing="20" style="-fx-background-color: #f0f4f8;">

        <!-- Médecin info + Bouton Gérer dispo -->
        <HBox alignment="CENTER_LEFT" spacing="15"
              style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);">

            <Label text="SA" prefWidth="45" prefHeight="45" alignment="CENTER"
                   style="-fx-background-color: #1a73e8; -fx-background-radius: 22; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 15;"/>
            <VBox spacing="3">
                <Label text="Dr. Sarah Amrani" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                <Label text="Planning des consultations" style="-fx-font-size: 12; -fx-text-fill: #999;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="btnGererDispo" text="📅 Gérer ma disponibilité"
                    style="-fx-background-color: #1a73e8; -fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 14 30; -fx-cursor: hand;"/>
        </HBox>

        <!-- Stats cards -->
        <HBox spacing="15">
            <HBox spacing="12" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);">
                <Label text="📅" style="-fx-font-size: 24; -fx-background-color: #e3f2fd; -fx-background-radius: 10; -fx-padding: 10;"/>
                <VBox spacing="3">
                    <Label text="AUJOURD'HUI" style="-fx-font-size: 11; -fx-text-fill: #999; -fx-font-weight: bold;"/>
                    <Label fx:id="lblTodayCount" text="0 RDV" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                </VBox>
            </HBox>

            <HBox spacing="12" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);">
                <Label text="⏳" style="-fx-font-size: 24; -fx-background-color: #fff3e0; -fx-background-radius: 10; -fx-padding: 10;"/>
                <VBox spacing="3">
                    <Label text="EN ATTENTE" style="-fx-font-size: 11; -fx-text-fill: #999; -fx-font-weight: bold;"/>
                    <Label fx:id="lblPendingCount" text="0 Demandes" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                </VBox>
            </HBox>

            <HBox spacing="12" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);">
                <Label text="✅" style="-fx-font-size: 24; -fx-background-color: #e8f5e9; -fx-background-radius: 10; -fx-padding: 10;"/>
                <VBox spacing="3">
                    <Label text="TERMINÉS" style="-fx-font-size: 11; -fx-text-fill: #999; -fx-font-weight: bold;"/>
                    <Label fx:id="lblDoneCount" text="0 Consultations" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                </VBox>
            </HBox>
        </HBox>

        <!-- ═══════ BARRE RECHERCHE + FILTRES + TRI ═══════ -->
        <HBox spacing="12" alignment="CENTER_LEFT"
              style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 16 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);">

            <!-- Recherche -->
            <TextField fx:id="searchField" promptText="🔍 Rechercher médecin, patient, motif..."
                       prefWidth="280"
                       style="-fx-font-size: 13; -fx-background-radius: 20; -fx-border-radius: 20; -fx-border-color: #e2e8f0; -fx-padding: 9 16; -fx-background-color: #f8fafc;"/>

            <Separator orientation="VERTICAL" prefHeight="30" style="-fx-padding: 0 4;"/>

            <!-- Filtre Statut -->
            <Label text="Statut:" style="-fx-font-size: 12; -fx-text-fill: #888; -fx-font-weight: bold;"/>
            <ComboBox fx:id="filterStatut" promptText="Tous" prefWidth="150"
                      style="-fx-font-size: 12; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e2e8f0;"/>

            <!-- Filtre Date -->
            <Label text="Période:" style="-fx-font-size: 12; -fx-text-fill: #888; -fx-font-weight: bold;"/>
            <ComboBox fx:id="filterDate" promptText="Toutes" prefWidth="160"
                      style="-fx-font-size: 12; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e2e8f0;"/>

            <Separator orientation="VERTICAL" prefHeight="30" style="-fx-padding: 0 4;"/>

            <!-- Tri -->
            <Label text="Trier:" style="-fx-font-size: 12; -fx-text-fill: #888; -fx-font-weight: bold;"/>
            <ComboBox fx:id="sortCombo" promptText="Date ↓" prefWidth="170"
                      style="-fx-font-size: 12; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e2e8f0;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Compteur résultats -->
            <Label fx:id="lblResultCount" text="0 résultat(s)"
                   style="-fx-font-size: 12; -fx-text-fill: #94a3b8; -fx-font-weight: bold;"/>

            <!-- Bouton reset -->
            <Button fx:id="btnReset" text="✕ Réinitialiser"
                    style="-fx-background-color: #f1f5f9; -fx-text-fill: #64748b; -fx-font-size: 11; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 14; -fx-cursor: hand; -fx-border-color: #e2e8f0; -fx-border-radius: 8;"/>
        </HBox>

        <!-- Tableau des RDV -->
        <VBox spacing="0"
              style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);">

            <!-- Header tableau -->
            <HBox alignment="CENTER_LEFT" style="-fx-padding: 15 25; -fx-border-color: #eee; -fx-border-width: 0 0 1 0; -fx-background-color: #f8fafc; -fx-background-radius: 12 12 0 0;">
                <Label text="RÉF." prefWidth="100" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
                <Label text="PATIENT" prefWidth="250" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
                <Label text="MÉDECIN" prefWidth="220" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
                <Label text="DATE &amp; HEURE" prefWidth="200" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
                <Label text="STATUT" prefWidth="150" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
                <Label text="ACTIONS" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
            </HBox>

            <!-- Liste des lignes RDV -->
            <VBox fx:id="rdvTableContainer" spacing="0"/>

            <!-- Message vide -->
            <VBox fx:id="emptyState" alignment="CENTER" spacing="8" managed="false" visible="false"
                  style="-fx-padding: 40;">
                <Label text="🔍" style="-fx-font-size: 36; -fx-opacity: 0.4;"/>
                <Label fx:id="lblEmptyMsg" text="Aucun rendez-vous trouvé"
                       style="-fx-font-size: 14; -fx-text-fill: #94a3b8; -fx-font-weight: bold;"/>
                <Label text="Essayez de modifier vos filtres"
                       style="-fx-font-size: 12; -fx-text-fill: #cbd5e1;"/>
            </VBox>
        </VBox>

    </VBox>
</ScrollPane>
