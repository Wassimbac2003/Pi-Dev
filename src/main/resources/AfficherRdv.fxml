<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="Controllers.AfficherRdvController"
      spacing="0"
      style="-fx-background-color: #f0f4f8;">

    <!-- ✅ BANNIÈRE DE RAPPELS — une seule ici, gérée par le controller -->
    <HBox fx:id="rappelBanner" visible="false" managed="false"
          style="-fx-background-color: #3b82f6; -fx-padding: 15 20;">
        <padding><Insets top="0" right="0" bottom="0" left="0"/></padding>
    </HBox>

    <!-- CONTENU PRINCIPAL -->
    <ScrollPane fitToWidth="true" fitToHeight="true"
                style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">

        <HBox spacing="20" style="-fx-background-color: #f0f4f8; -fx-padding: 20;">

            <!-- ==================== COLONNE GAUCHE ==================== -->
            <VBox spacing="18" HBox.hgrow="ALWAYS">

                <!-- Barre du haut : Historique -->
                <HBox alignment="CENTER_LEFT" spacing="15">
                    <Button fx:id="btnHistorique" text="🕐 Historique"
                            style="-fx-background-color: white; -fx-text-fill: #555; -fx-font-size: 13; -fx-background-radius: 20; -fx-border-radius: 20; -fx-border-color: #ddd; -fx-padding: 8 20; -fx-cursor: hand;"/>
                </HBox>

                <!-- Carte bleue : Prochain RDV -->
                <HBox fx:id="carteProchainRdv" prefHeight="160" spacing="0"
                      style="-fx-background-color: linear-gradient(to right, #4a6cf7, #6a8fff); -fx-background-radius: 15; -fx-padding: 25;">

                    <VBox spacing="8" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="🔔" style="-fx-font-size: 14;"/>
                            <Label text="Prochain Rendez-vous"
                                   style="-fx-font-size: 13; -fx-text-fill: white; -fx-background-color: rgba(255,255,255,0.2); -fx-background-radius: 15; -fx-padding: 4 12;"/>
                        </HBox>
                        <Label fx:id="prochainMedecin" text="Dr. Sarah Amrani"
                               style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label fx:id="prochainMotif" text="Consultation"
                               style="-fx-font-size: 14; -fx-text-fill: rgba(255,255,255,0.8);"/>
                        <HBox spacing="10" style="-fx-padding: 8 0 0 0;">
                            <Button text="📹 Lancer Visio"
                                    style="-fx-background-color: white; -fx-text-fill: #4a6cf7; -fx-font-size: 12; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 15; -fx-cursor: hand;"/>
                            <Button text="Détails"
                                    style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-font-size: 12; -fx-background-radius: 8; -fx-padding: 8 15; -fx-cursor: hand; -fx-border-color: rgba(255,255,255,0.4); -fx-border-radius: 8;"/>
                        </HBox>
                    </VBox>

                    <VBox alignment="CENTER" spacing="2"
                          style="-fx-background-color: rgba(255,255,255,0.15); -fx-background-radius: 12; -fx-padding: 15 25;">
                        <Label fx:id="prochainMois" text="APR"
                               style="-fx-font-size: 13; -fx-text-fill: rgba(255,255,255,0.8);"/>
                        <Label fx:id="prochainJour" text="10"
                               style="-fx-font-size: 42; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label fx:id="prochainHeure" text="09:00"
                               style="-fx-font-size: 14; -fx-text-fill: rgba(255,255,255,0.8);"/>
                    </VBox>
                </HBox>

                <!-- Onglets + Recherche -->
                <HBox alignment="CENTER_LEFT" spacing="20">
                    <Label fx:id="tabAVenir" text="À venir"
                           style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #1a73e8; -fx-border-color: #1a73e8; -fx-border-width: 0 0 2 0; -fx-padding: 0 5 8 5; -fx-cursor: hand;"/>
                    <Label fx:id="tabPasses" text="Passés"
                           style="-fx-font-size: 14; -fx-text-fill: #999; -fx-padding: 0 5 8 5; -fx-cursor: hand;"/>
                    <Label fx:id="tabAnnules" text="Annulés"
                           style="-fx-font-size: 14; -fx-text-fill: #999; -fx-padding: 0 5 8 5; -fx-cursor: hand;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <TextField fx:id="searchField" promptText="🔍 Rechercher..."
                               prefWidth="220"
                               style="-fx-font-size: 13; -fx-background-radius: 20; -fx-border-radius: 20; -fx-border-color: #ddd; -fx-padding: 8 15;"/>
                </HBox>

                <!-- Liste des cartes RDV -->
                <VBox fx:id="rdvListContainer" spacing="12" style="-fx-padding: 5 5 5 0;"/>

            </VBox>

            <!-- ==================== COLONNE DROITE ==================== -->
            <VBox spacing="20" prefWidth="300" minWidth="300" maxWidth="300">

                <!-- Bouton Ajouter RDV -->
                <HBox alignment="CENTER_RIGHT">
                    <Button fx:id="btnAjouter" text="+ Ajouter RDV"
                            style="-fx-background-color: #1a73e8; -fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 12 25; -fx-cursor: hand;"/>
                </HBox>

                <!-- Calendrier dynamique -->
                <VBox spacing="10"
                      style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);">

                    <HBox alignment="CENTER" spacing="10">
                        <Button fx:id="btnCalPrev" text="‹" style="-fx-background-color: transparent; -fx-font-size: 16; -fx-cursor: hand;"/>
                        <Label fx:id="calendarMonthLabel" text="Avril 2026" style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                        <Button fx:id="btnCalNext" text="›" style="-fx-background-color: transparent; -fx-font-size: 16; -fx-cursor: hand;"/>
                    </HBox>

                    <GridPane alignment="CENTER" hgap="0">
                        <Label text="L" prefWidth="38" alignment="CENTER" style="-fx-font-size: 12; -fx-text-fill: #999;" GridPane.columnIndex="0"/>
                        <Label text="M" prefWidth="38" alignment="CENTER" style="-fx-font-size: 12; -fx-text-fill: #999;" GridPane.columnIndex="1"/>
                        <Label text="M" prefWidth="38" alignment="CENTER" style="-fx-font-size: 12; -fx-text-fill: #999;" GridPane.columnIndex="2"/>
                        <Label text="J" prefWidth="38" alignment="CENTER" style="-fx-font-size: 12; -fx-text-fill: #999;" GridPane.columnIndex="3"/>
                        <Label text="V" prefWidth="38" alignment="CENTER" style="-fx-font-size: 12; -fx-text-fill: #999;" GridPane.columnIndex="4"/>
                        <Label text="S" prefWidth="38" alignment="CENTER" style="-fx-font-size: 12; -fx-text-fill: #e53935;" GridPane.columnIndex="5"/>
                        <Label text="D" prefWidth="38" alignment="CENTER" style="-fx-font-size: 12; -fx-text-fill: #e53935;" GridPane.columnIndex="6"/>
                    </GridPane>

                    <GridPane fx:id="calendarGrid" alignment="CENTER" hgap="2" vgap="2"/>

                    <Label text="📅 Cliquez sur une date pour prendre RDV"
                           style="-fx-font-size: 11; -fx-text-fill: #999; -fx-padding: 10 0 0 0;"
                           wrapText="true"/>
                </VBox>

                <!-- Mes Médecins (dynamique + scrollable) -->
                <VBox spacing="12"
                      style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);">

                    <HBox alignment="CENTER_LEFT">
                        <Label text="Mes Médecins" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="lblVoirTout" text="Voir tout" style="-fx-font-size: 12; -fx-text-fill: #1a73e8; -fx-cursor: hand; -fx-underline: true;"/>
                    </HBox>

                    <ScrollPane fx:id="medecinScrollPane" fitToWidth="true" prefHeight="180" maxHeight="180"
                                style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
                        <VBox fx:id="medecinListContainer" spacing="8"/>
                    </ScrollPane>

                    <TextField fx:id="searchMedecinField" promptText="🔍 Trouver un spécialiste"
                               style="-fx-font-size: 12; -fx-background-radius: 20; -fx-border-radius: 20; -fx-border-color: #ddd; -fx-padding: 8 15;"/>
                </VBox>
            </VBox>
        </HBox>
    </ScrollPane>
</VBox>
