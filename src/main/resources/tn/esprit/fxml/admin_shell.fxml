<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.AdminShellController"
            styleClass="admin-shell"
            stylesheets="@../styles/app.css">
    <left>
        <VBox styleClass="sidebar" spacing="0" alignment="TOP_CENTER">
            <VBox styleClass="sidebar-brand">
                <Label text="CareConsole" styleClass="sidebar-brand-title"/>
                <Label text="Administration" styleClass="sidebar-brand-sub"/>
            </VBox>
            <Separator/>
            <VBox styleClass="sidebar-nav" spacing="6">
                <Button fx:id="navMedicaments" text="Médicaments" maxWidth="Infinity" onAction="#showMedicaments"
                        styleClass="nav-item" mnemonicParsing="false"/>
                <Button fx:id="navFiches" text="Fiches médicales" maxWidth="Infinity" onAction="#showFiches"
                        styleClass="nav-item" mnemonicParsing="false"/>
                <Button fx:id="navOrdonnances" text="Ordonnances" maxWidth="Infinity" onAction="#showOrdonnances"
                        styleClass="nav-item" mnemonicParsing="false"/>
            </VBox>
            <Region VBox.vgrow="ALWAYS"/>
            <VBox styleClass="sidebar-footer">
                <Separator/>
                <Button text="Déconnexion" maxWidth="Infinity" onAction="#onLogout" styleClass="danger-button"
                        mnemonicParsing="false"/>
            </VBox>
        </VBox>
    </left>
    <center>
        <StackPane fx:id="contentPane" styleClass="content-shell"/>
    </center>
</BorderPane>
