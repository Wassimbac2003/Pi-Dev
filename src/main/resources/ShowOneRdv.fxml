<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="Controllers.ShowOneRdvController"
            fitToWidth="true"
            style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">

    <VBox spacing="20" style="-fx-background-color: #f0f4f8; -fx-padding: 5;">

        <!-- Retour -->
        <Button fx:id="btnRetour" text="← Retour aux rendez-vous"
                style="-fx-background-color: transparent; -fx-text-fill: #555; -fx-font-size: 14; -fx-cursor: hand; -fx-padding: 5 0;"/>

        <!-- Carte bleue principale -->
        <HBox prefHeight="220" spacing="0"
              style="-fx-background-color: linear-gradient(to right, #4a6cf7, #6a8fff); -fx-background-radius: 15; -fx-padding: 30;">

            <VBox spacing="10" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="📅" style="-fx-font-size: 14;"/>
                    <Label text="Détails du Rendez-vous"
                           style="-fx-font-size: 13; -fx-text-fill: white; -fx-background-color: rgba(255,255,255,0.2); -fx-background-radius: 15; -fx-padding: 4 12;"/>
                </HBox>

                <Label fx:id="lblMedecin" text="Dr. Sarah Amrani"
                       style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: white;"/>

                <Label fx:id="lblMotif" text="Consultation"
                       style="-fx-font-size: 15; -fx-text-fill: rgba(255,255,255,0.8);"/>

                <HBox spacing="10" style="-fx-padding: 10 0 0 0;">
                    <Label fx:id="lblDateBadge" text="📅 10/04/2026"
                           style="-fx-font-size: 12; -fx-text-fill: white; -fx-background-color: rgba(255,255,255,0.2); -fx-background-radius: 15; -fx-padding: 6 14;"/>
                    <Label fx:id="lblHoraireBadge" text="🕐 09:00 - 09:30"
                           style="-fx-font-size: 12; -fx-text-fill: white; -fx-background-color: rgba(255,255,255,0.2); -fx-background-radius: 15; -fx-padding: 6 14;"/>
                    <Label fx:id="lblStatutBadge" text="⏳ En attente"
                           style="-fx-font-size: 12; -fx-text-fill: white; -fx-background-color: #ff9800; -fx-background-radius: 15; -fx-padding: 6 14;"/>
                </HBox>

                <HBox spacing="10" style="-fx-padding: 8 0 0 0;">
                    <Button text="📹 Lancer Visio"
                            style="-fx-background-color: white; -fx-text-fill: #4a6cf7; -fx-font-size: 12; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 15; -fx-cursor: hand;"/>
                    <Button fx:id="btnModifier" text="✏ Modifier"
                            style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-font-size: 12; -fx-background-radius: 8; -fx-padding: 8 15; -fx-cursor: hand; -fx-border-color: rgba(255,255,255,0.4); -fx-border-radius: 8;"/>
                </HBox>
            </VBox>

            <VBox alignment="CENTER" spacing="2"
                  style="-fx-background-color: rgba(255,255,255,0.15); -fx-background-radius: 12; -fx-padding: 20 30;">
                <Label fx:id="lblMois" text="APR"
                       style="-fx-font-size: 14; -fx-text-fill: rgba(255,255,255,0.8);"/>
                <Label fx:id="lblJour" text="10"
                       style="-fx-font-size: 48; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label fx:id="lblHeure" text="09:00"
                       style="-fx-font-size: 14; -fx-text-fill: rgba(255,255,255,0.8);"/>
            </VBox>
        </HBox>

        <!-- Infos Générales + Message -->
        <HBox spacing="20">

            <!-- Informations Générales -->
            <VBox spacing="0" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);">

                <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-padding: 0 0 20 0;">
                    <Label text="ℹ️" style="-fx-font-size: 16;"/>
                    <Label text="Informations Générales"
                           style="-fx-font-size: 17; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" style="-fx-padding: 18 0; -fx-border-color: #f0f0f0; -fx-border-width: 1 0 0 0;">
                    <Label text="Médecin" style="-fx-font-size: 14; -fx-text-fill: #999;" HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblInfoMedecin" text="Dr. Sarah Amrani"
                           style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" style="-fx-padding: 18 0; -fx-border-color: #f0f0f0; -fx-border-width: 1 0 0 0;">
                    <Label text="Motif" style="-fx-font-size: 14; -fx-text-fill: #999;" HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblInfoMotif" text="Consultation"
                           style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" style="-fx-padding: 18 0; -fx-border-color: #f0f0f0; -fx-border-width: 1 0 0 0;">
                    <Label text="Date" style="-fx-font-size: 14; -fx-text-fill: #999;" HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblInfoDate" text="10/04/2026"
                           style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" style="-fx-padding: 18 0; -fx-border-color: #f0f0f0; -fx-border-width: 1 0 0 0;">
                    <Label text="Horaire" style="-fx-font-size: 14; -fx-text-fill: #999;" HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblInfoHoraire" text="09:00 - 09:30"
                           style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" style="-fx-padding: 18 0; -fx-border-color: #f0f0f0; -fx-border-width: 1 0 0 0;">
                    <Label text="Statut" style="-fx-font-size: 14; -fx-text-fill: #999;" HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblInfoStatut" text="⏳ En attente"
                           style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #ff9800; -fx-background-color: #fff3e0; -fx-background-radius: 15; -fx-padding: 4 12;"/>
                </HBox>
            </VBox>

            <!-- Message & Actions -->
            <VBox spacing="20" prefWidth="350" minWidth="350">

                <!-- Message -->
                <VBox spacing="12"
                      style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);">
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="💬" style="-fx-font-size: 16;"/>
                        <Label text="Message &amp; Notes"
                               style="-fx-font-size: 17; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                    </HBox>
                    <Label fx:id="lblMessage" text="Paiement: sur_place" wrapText="true"
                           style="-fx-font-size: 13; -fx-text-fill: #555; -fx-background-color: #f8f9fa; -fx-background-radius: 10; -fx-padding: 18;"/>
                </VBox>

                <!-- Actions Rapides -->
                <VBox spacing="12"
                      style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);">
                    <Label text="Actions Rapides"
                           style="-fx-font-size: 17; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                    <Button fx:id="btnSmsRappel" text="📱 SMS Rappel" maxWidth="Infinity"
                            style="-fx-background-color: #16a34a; -fx-text-fill: white; -fx-font-size: 13; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 14; -fx-cursor: hand;"/>
                    <Label fx:id="lblSmsInfo" text="ℹ️ Le SMS sera envoyé le jour même du RDV."
                           wrapText="true"
                           style="-fx-font-size: 11; -fx-text-fill: #999;"/>
                </VBox>
            </VBox>
        </HBox>

        <!-- Préparation & Instructions -->
        <VBox spacing="15"
              style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);">

            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="📋" style="-fx-font-size: 16;"/>
                <Label text="Préparation &amp; Instructions"
                       style="-fx-font-size: 17; -fx-font-weight: bold; -fx-text-fill: #333;"/>
            </HBox>

            <HBox spacing="15">
                <VBox spacing="10" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #e8f5e9; -fx-background-radius: 12; -fx-padding: 20;">
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="✅" style="-fx-font-size: 16;"/>
                        <Label text="À faire" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #2e7d32;"/>
                    </HBox>
                    <Label text="• Arriver 10 min en avance" style="-fx-font-size: 12; -fx-text-fill: #555;"/>
                    <Label text="• Apporter carte vitale" style="-fx-font-size: 12; -fx-text-fill: #555;"/>
                    <Label text="• Porter un masque" style="-fx-font-size: 12; -fx-text-fill: #555;"/>
                </VBox>

                <VBox spacing="10" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #e3f2fd; -fx-background-radius: 12; -fx-padding: 20;">
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="📍" style="-fx-font-size: 16;"/>
                        <Label text="Lieu" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #1565c0;"/>
                    </HBox>
                    <Label text="Clinique Pasteur" style="-fx-font-size: 12; -fx-text-fill: #555;"/>
                    <Label text="123 Avenue de la Santé" style="-fx-font-size: 12; -fx-text-fill: #555;"/>
                    <Label text="Tunis, Tunisie" style="-fx-font-size: 12; -fx-text-fill: #555;"/>
                </VBox>

                <VBox spacing="10" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #fff3e0; -fx-background-radius: 12; -fx-padding: 20;">
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="📞" style="-fx-font-size: 16;"/>
                        <Label text="Contact" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #e65100;"/>
                    </HBox>
                    <Label text="Tél: +216 71 123 456" style="-fx-font-size: 12; -fx-text-fill: #555;"/>
                    <Label text="Email: contact@clinique.tn" style="-fx-font-size: 12; -fx-text-fill: #555;"/>
                </VBox>
            </HBox>
        </VBox>

        <!-- Barre du bas -->
        <HBox alignment="CENTER_LEFT" spacing="15"
              style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);">

            <Label fx:id="lblDateCreation" text="ℹ️ Rendez-vous créé le 10/04/2026"
                   style="-fx-font-size: 12; -fx-text-fill: #999;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button fx:id="btnModifierBas" text="✏ Modifier"
                    style="-fx-background-color: #ff9800; -fx-text-fill: white; -fx-font-size: 13; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 25; -fx-cursor: hand;"/>

            <Button fx:id="btnAnnuler" text="✕ Annuler RDV"
                    style="-fx-background-color: white; -fx-text-fill: #e53935; -fx-font-size: 13; -fx-font-weight: bold; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e53935; -fx-padding: 10 25; -fx-cursor: hand;"/>
        </HBox>

    </VBox>
</ScrollPane>
