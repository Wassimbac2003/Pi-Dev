<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<ScrollPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="Controllers.AfficherRdvController"
            fitToWidth="true" fitToHeight="true"
            style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">

    <HBox spacing="20" style="-fx-background-color: #f0f4f8; -fx-padding: 0;">

        <!-- ==================== COLONNE GAUCHE ==================== -->
        <VBox spacing="18" HBox.hgrow="ALWAYS">

            <!-- Barre du haut : Historique seulement -->
            <HBox alignment="CENTER_LEFT" spacing="15">
                <Button text="🕐 Historique"
                        style="-fx-background-color: white; -fx-text-fill: #555; -fx-font-size: 13; -fx-background-radius: 20; -fx-border-radius: 20; -fx-border-color: #ddd; -fx-padding: 8 20; -fx-cursor: hand;"/>
            </HBox>

            <!-- Carte bleue : Prochain RDV -->
            <HBox prefHeight="160" spacing="0"
                  style="-fx-background-color: linear-gradient(to right, #4a6cf7, #6a8fff); -fx-background-radius: 15; -fx-padding: 25;">

                <VBox spacing="8" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="🔔" style="-fx-font-size: 14;"/>
                        <Label text="Prochain Rendez-vous"
                               style="-fx-font-size: 13; -fx-text-fill: white; -fx-background-color: rgba(255,255,255,0.2); -fx-background-radius: 15; -fx-padding: 4 12;"/>
                    </HBox>
                    <Label fx:id="prochainMedecin" text="Dr. Sarah Amrani"
                           style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Label fx:id="prochainMotif" text="Consultation"
                           style="-fx-font-size: 14; -fx-text-fill: rgba(255,255,255,0.8);"/>
                    <HBox spacing="10" style="-fx-padding: 8 0 0 0;">
                        <Button text="📹 Lancer Visio"
                                style="-fx-background-color: white; -fx-text-fill: #4a6cf7; -fx-font-size: 12; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 15; -fx-cursor: hand;"/>
                        <Button text="Détails"
                                style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-font-size: 12; -fx-background-radius: 8; -fx-padding: 8 15; -fx-cursor: hand; -fx-border-color: rgba(255,255,255,0.4); -fx-border-radius: 8;"/>
                    </HBox>
                </VBox>

                <VBox alignment="CENTER" spacing="2"
                      style="-fx-background-color: rgba(255,255,255,0.15); -fx-background-radius: 12; -fx-padding: 15 25;">
                    <Label fx:id="prochainMois" text="APR"
                           style="-fx-font-size: 13; -fx-text-fill: rgba(255,255,255,0.8);"/>
                    <Label fx:id="prochainJour" text="10"
                           style="-fx-font-size: 42; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Label fx:id="prochainHeure" text="09:00"
                           style="-fx-font-size: 14; -fx-text-fill: rgba(255,255,255,0.8);"/>
                </VBox>
            </HBox>

            <!-- Onglets + Recherche -->
            <HBox alignment="CENTER_LEFT" spacing="20">
                <Label text="À venir"
                       style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #1a73e8; -fx-border-color: #1a73e8; -fx-border-width: 0 0 2 0; -fx-padding: 0 5 8 5;"/>
                <Label text="Passés" style="-fx-font-size: 14; -fx-text-fill: #999; -fx-padding: 0 5 8 5;"/>
                <Label text="Annulés" style="-fx-font-size: 14; -fx-text-fill: #999; -fx-padding: 0 5 8 5;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <TextField fx:id="searchField" promptText="🔍 Rechercher..."
                           prefWidth="220"
                           style="-fx-font-size: 13; -fx-background-radius: 20; -fx-border-radius: 20; -fx-border-color: #ddd; -fx-padding: 8 15;"/>
            </HBox>

            <!-- Liste des cartes RDV -->
            <VBox fx:id="rdvListContainer" spacing="12" style="-fx-padding: 5 5 5 0;"/>

        </VBox>

        <!-- ==================== COLONNE DROITE ==================== -->
        <VBox spacing="20" prefWidth="300" minWidth="300" maxWidth="300">

            <!-- Bouton Ajouter RDV -->
            <HBox alignment="CENTER_RIGHT">
                <Button fx:id="btnAjouter" text="+ Ajouter RDV"
                        style="-fx-background-color: #1a73e8; -fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 12 25; -fx-cursor: hand;"/>
            </HBox>

            <!-- Calendrier -->
            <VBox spacing="10"
                  style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);">

                <HBox alignment="CENTER" spacing="10">
                    <Button text="‹" style="-fx-background-color: transparent; -fx-font-size: 16; -fx-cursor: hand;"/>
                    <Label text="Avril 2026" style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                    <Button text="›" style="-fx-background-color: transparent; -fx-font-size: 16; -fx-cursor: hand;"/>
                </HBox>

                <HBox alignment="CENTER" spacing="0">
                    <Label text="L" prefWidth="38" alignment="CENTER" style="-fx-font-size: 12; -fx-text-fill: #999;"/>
                    <Label text="M" prefWidth="38" alignment="CENTER" style="-fx-font-size: 12; -fx-text-fill: #999;"/>
                    <Label text="M" prefWidth="38" alignment="CENTER" style="-fx-font-size: 12; -fx-text-fill: #999;"/>
                    <Label text="J" prefWidth="38" alignment="CENTER" style="-fx-font-size: 12; -fx-text-fill: #999;"/>
                    <Label text="V" prefWidth="38" alignment="CENTER" style="-fx-font-size: 12; -fx-text-fill: #999;"/>
                    <Label text="S" prefWidth="38" alignment="CENTER" style="-fx-font-size: 12; -fx-text-fill: #e53935;"/>
                    <Label text="D" prefWidth="38" alignment="CENTER" style="-fx-font-size: 12; -fx-text-fill: #e53935;"/>
                </HBox>

                <Label text="📅 Cliquez sur une date pour prendre RDV"
                       style="-fx-font-size: 11; -fx-text-fill: #999; -fx-padding: 20 0 0 0;"
                       wrapText="true"/>
            </VBox>

            <!-- Mes Médecins -->
            <VBox spacing="12"
                  style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);">

                <HBox alignment="CENTER_LEFT">
                    <Label text="Mes Médecins" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="Voir tout" style="-fx-font-size: 12; -fx-text-fill: #1a73e8; -fx-cursor: hand;"/>
                </HBox>

                <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-padding: 5 0;">
                    <Label text="SA" prefWidth="40" prefHeight="40" alignment="CENTER"
                           style="-fx-background-color: #1a73e8; -fx-background-radius: 20; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13;"/>
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="Dr. S. Amrani" style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                        <Label text="Cardiologue" style="-fx-font-size: 11; -fx-text-fill: #999;"/>
                    </VBox>
                    <Label text="📅" style="-fx-font-size: 14; -fx-cursor: hand;"/>
                </HBox>

                <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-padding: 5 0;">
                    <Label text="MK" prefWidth="40" prefHeight="40" alignment="CENTER"
                           style="-fx-background-color: #888; -fx-background-radius: 20; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13;"/>
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="Dr. M. Kallel" style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                        <Label text="Ophtalmo" style="-fx-font-size: 11; -fx-text-fill: #999;"/>
                    </VBox>
                    <Label text="📅" style="-fx-font-size: 14; -fx-cursor: hand;"/>
                </HBox>

                <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-padding: 5 0;">
                    <Label text="AZ" prefWidth="40" prefHeight="40" alignment="CENTER"
                           style="-fx-background-color: #bbb; -fx-background-radius: 20; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13;"/>
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="Dr. A. Zouhaier" style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                        <Label text="Neurologie" style="-fx-font-size: 11; -fx-text-fill: #999;"/>
                    </VBox>
                    <Label text="📅" style="-fx-font-size: 14; -fx-cursor: hand;"/>
                </HBox>

                <TextField promptText="🔍 Trouver un spécialiste"
                           style="-fx-font-size: 12; -fx-background-radius: 20; -fx-border-radius: 20; -fx-border-color: #ddd; -fx-padding: 8 15;"/>
            </VBox>
        </VBox>
    </HBox>
</ScrollPane>