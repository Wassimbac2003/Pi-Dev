<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.healthtrack.controllers.AdminMissionsPageController"
            fitToWidth="true"
            hbarPolicy="NEVER"
            styleClass="admin-scroll">
    <content>
        <VBox spacing="24.0" styleClass="admin-page-root">
            <padding>
                <Insets top="24.0" right="24.0" bottom="24.0" left="24.0"/>
            </padding>
            <children>
                <VBox spacing="12.0" styleClass="admin-page-banner">
                    <children>
                        <HBox alignment="CENTER_LEFT">
                            <children>
                                <Label text="Gestion des Missions Bénévoles" styleClass="admin-page-title"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <HBox spacing="12.0">
                                    <children>
                                        <Button text="Dashboard IA" onAction="#refreshRows" styleClass="admin-blue-button"/>
                                        <Button text="Gérer les Sponsors" onAction="#openSponsors" styleClass="admin-purple-button"/>
                                        <Button text="Créer une Mission" onAction="#openMissionForm" styleClass="admin-orange-button"/>
                                    </children>
                                </HBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>
                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <children>
                        <Label fx:id="totalLabel" styleClass="admin-total-label"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <TextField fx:id="searchField" promptText="Rechercher..." styleClass="admin-search-field"/>
                        <ComboBox fx:id="applicationFilterBox" styleClass="admin-filter-box"/>
                        <Button text="Rechercher" onAction="#refreshRows" styleClass="admin-search-button"/>
                    </children>
                </HBox>
                <VBox fx:id="rowsContainer" styleClass="admin-table-card"/>
            </children>
        </VBox>
    </content>
</ScrollPane>
