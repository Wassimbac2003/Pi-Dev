<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:controller="com.healthtrack.controllers.MainController"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            styleClass="app-shell">
    <left>
        <VBox spacing="12.0" prefWidth="240.0" styleClass="sidebar">
            <padding>
                <Insets top="26.0" right="18.0" bottom="20.0" left="18.0"/>
            </padding>
            <children>
                <Label text="VitalTrack" styleClass="brand-label"/>
                <Label text="MENU PRINCIPAL" styleClass="menu-section-title">
                    <VBox.margin>
                        <Insets top="18.0" bottom="4.0"/>
                    </VBox.margin>
                </Label>
                <Button fx:id="dashboardButton" text="Tableau de Bord" styleClass="nav-button" maxWidth="1.7976931348623157E308" alignment="CENTER_LEFT" onAction="#showMissionsPage"/>
                <Button fx:id="meetingButton" text="Rendez-vous" styleClass="nav-button" maxWidth="1.7976931348623157E308" alignment="CENTER_LEFT" onAction="#showRendezVousModule"/>
                <Button fx:id="medicineButton" text="Medicaments" styleClass="nav-button" maxWidth="1.7976931348623157E308" alignment="CENTER_LEFT" onAction="#showVolunteersPage"/>
                <Button fx:id="statsButton" text="Mes Statistiques" styleClass="nav-button" maxWidth="1.7976931348623157E308" alignment="CENTER_LEFT" onAction="#showLinksPage"/>
                <Label text="COMMUNAUTE" styleClass="menu-section-title">
                    <VBox.margin>
                        <Insets top="10.0" bottom="4.0"/>
                    </VBox.margin>
                </Label>
                <Button fx:id="missionsButton" text="Gerer mes missions" styleClass="nav-button" maxWidth="1.7976931348623157E308" alignment="CENTER_LEFT" onAction="#showMissionsPage"/>
                <Button fx:id="benevolatButton" text="Benevolat" styleClass="nav-button" maxWidth="1.7976931348623157E308" alignment="CENTER_LEFT" onAction="#showBenevolatPage"/>
                <Button fx:id="sponsorsButton" text="Annonces &amp; Dons" styleClass="nav-button" maxWidth="1.7976931348623157E308" alignment="CENTER_LEFT" onAction="#showSponsorsPage"/>
                <Button fx:id="volunteersButton" text="Gerer mes Missions" styleClass="nav-button" maxWidth="1.7976931348623157E308" alignment="CENTER_LEFT" onAction="#showVolunteersPage"/>
                <Button fx:id="linksButton" text="Backoffice" styleClass="nav-button" maxWidth="1.7976931348623157E308" alignment="CENTER_LEFT" onAction="#showLinksPage"/>
                <Region VBox.vgrow="ALWAYS"/>
                <Separator/>
                <Label text="Mon compte" styleClass="footer-link"/>
                <Label text="Deconnexion" styleClass="footer-link"/>
            </children>
        </VBox>
    </left>
    <center>
        <BorderPane styleClass="main-content">
            <top>
                <HBox alignment="CENTER_LEFT" spacing="16.0" styleClass="topbar">
                    <padding>
                        <Insets top="18.0" right="24.0" bottom="18.0" left="24.0"/>
                    </padding>
                    <children>
                        <Label fx:id="pageTitleLabel" text="Gestion des missions" styleClass="page-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="3" styleClass="notification-pill"/>
                        <VBox alignment="CENTER_RIGHT" spacing="2.0">
                            <children>
                                <Label text="Firas Ben Hamouda" styleClass="user-name"/>
                                <Label text="benhamoudafiras19@gmail.com" styleClass="user-mail"/>
                            </children>
                        </VBox>
                        <Label text="FH" styleClass="avatar"/>
                    </children>
                </HBox>
            </top>
            <center>
                <StackPane fx:id="contentPane">
                    <BorderPane.margin>
                        <Insets top="0.0" right="24.0" bottom="24.0" left="24.0"/>
                    </BorderPane.margin>
                </StackPane>
            </center>
        </BorderPane>
    </center>
</BorderPane>
